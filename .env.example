# Required: Anthropic API key for the reasoning model
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default models
SENTINEL_MODEL=claude-sonnet-4-6
SENTINEL_JUDGE_MODEL=claude-opus-4-8

# Optional: max agent steps before giving up (default 40)
SENTINEL_MAX_STEPS=40

# Optional: wall-clock budget per spec in ms before the run is halted (default 300000 = 5m)
SENTINEL_MAX_DURATION_MS=300000

# Optional: run headed (default headless)
SENTINEL_HEADED=false

# Optional: record a video of each run (default false)
SENTINEL_VIDEO=false

# Optional: post suite results to a webhook on completion (Slack auto-detected by URL)
SENTINEL_SLACK_WEBHOOK=
SENTINEL_WEBHOOK_URL=
